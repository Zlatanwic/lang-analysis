  "metadata": {
    "description": "Programming Language Type System Feature Matrix",
    "scoring": {
      "0": "Not supported",
      "1": "Partial / limited support",
      "2": "Full support"
    },
    "features": {
      "parametric_polymorphism": "Generics / parametric polymorphism",
      "ad_hoc_polymorphism": "Trait / typeclass / interface-based polymorphism",
      "algebraic_data_types": "Sum types + product types (tagged unions, enums with data)",
      "pattern_matching": "Exhaustive pattern matching on types",
      "ownership_lifetime": "Ownership / lifetime / borrow checking",
      "dependent_types": "Types that depend on values",
      "gadts": "Generalized algebraic data types",
      "higher_kinded_types": "Type constructors as parameters (HKT)",
      "effect_system": "Tracked computational effects in the type system",
      "refinement_types": "Types refined by predicates",
      "gradual_typing": "Mix of static and dynamic typing",
      "type_inference": "Automatic type deduction without annotations",
      "structural_typing": "Compatibility based on structure, not name",
      "flow_sensitive_typing": "Type narrowing based on control flow"
    }
  },
